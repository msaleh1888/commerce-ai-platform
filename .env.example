COMMERCE_AI_ENVIRONMENT=local
COMMERCE_AI_API_NAME=Commerce AI API
COMMERCE_AI_API_VERSION=0.1.0
COMMERCE_AI_LOG_LEVEL=INFO
COMMERCE_AI_DATABASE_URL=postgresql+psycopg://commerce_ai:commerce_ai@localhost:5432/commerce_ai
COMMERCE_AI_REDIS_URL=redis://localhost:6379/0
COMMERCE_AI_QDRANT_URL=http://localhost:6333

COMMERCE_AI_WORKER_ENVIRONMENT=local
COMMERCE_AI_WORKER_BROKER_URL=redis://localhost:6379/0
COMMERCE_AI_WORKER_RESULT_BACKEND=redis://localhost:6379/1
COMMERCE_AI_WORKER_TASK_DEFAULT_QUEUE=commerce_ai
COMMERCE_AI_WORKER_TASK_ALWAYS_EAGER=false
